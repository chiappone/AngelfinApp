generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./angelfin.db"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Movie {
  id          String   @id @default(cuid())
  tmdbId      Int?     @unique
  imdbId      String?
  title       String
  year        Int?
  posterPath  String?
  overview    String?
  mediaType   String   @default("movie") // movie, series, episode
  filters     Filter[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Filter {
  id          String   @id @default(cuid())
  movieId     String
  movie       Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  version     Int      @default(1)
  label       String   // e.g. "Family Friendly", "TV-14", custom name
  description String?
  filtersJson String   // the full Angelfin filter JSON
  source      String   @default("user") // user, ai-generated, videoskip-import
  isVerified  Boolean  @default(false)
  downloads   Int      @default(0)
  createdBy   String?  // user who uploaded
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([movieId])
  @@index([isVerified])
}
